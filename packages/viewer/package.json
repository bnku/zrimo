{
  "name": "@zrimo/viewer",
  "version": "0.1.1",
  "description": "Zrimo — embeddable browser-only document viewer with Rust/WASM adapters",
  "keywords": [
    "document-viewer",
    "wasm",
    "pdf",
    "docx",
    "xlsx",
    "pptx"
  ],
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bnku/zrimo.git",
    "directory": "packages/viewer"
  },
  "homepage": "https://bnku.github.io/zrimo/",
  "bugs": {
    "url": "https://github.com/bnku/zrimo/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "bin": {
    "zrimo-copy-assets": "./bin/copy-assets.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    },
    "./styles.css": "./dist/styles.css",
    "./fonts/*": "./dist/fonts/*",
    "./workers/*": "./dist/workers/*",
    "./assets/*": "./dist/assets/*"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "engines": {
    "node": ">=22.13.0 || >=24"
  },
  "scripts": {
    "build": "node ../../scripts/build-viewer.mjs",
    "test": "node ../../scripts/test-viewer.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@silurus/ooxml": "0.72.2",
    "pdfjs-dist": "6.1.200"
  }
}
